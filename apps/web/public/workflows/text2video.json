{
  "1": {
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    },
    "class_type": "CheckpointLoaderSimple"
  },
  "2": {
    "inputs": {
      "text": "{{prompt}}"
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Positive Prompt"
    }
  },
  "3": {
    "inputs": {
      "text": "low quality, jittery, worst quality, blurry, distorted"
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Negative Prompt"
    }
  },
  "4": {
    "inputs": {
      "width": "{{width}}",
      "height": "{{height}}",
      "frames": {{frames}},
      "batch_size": 1
    },
    "class_type": "EmptyLatentVideo"
  },
  "5": {
    "inputs": {
      "seed": {{seed}},
      "steps": {{steps}},
      "cfg": {{cfgScale}},
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1,
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0]
    },
    "class_type": "KSampler"
  },
  "6": {
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode"
  },
  "7": {
    "inputs": {
      "images": ["6", 0],
      "fps": {{fps}}
    },
    "class_type": "CreateVideo",
    "_meta": {
      "title": "Create Video"
    }
  },
  "8": {
    "inputs": {
      "video": ["7", 0],
      "filename_prefix": "OpenCut_text2video",
      "format": "mp4",
      "codec": "h264"
    },
    "class_type": "SaveVideo",
    "_meta": {
      "title": "Save Video"
    }
  }
}