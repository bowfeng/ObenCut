# ComfyUI AI Provider Configuration
# Copy this file to .env and configure your settings

# ComfyUI Server Settings
# WSL2 Users: Use host.docker.internal to access Windows ComfyUI
# Docker Users: Use host.docker.internal or actual container IP
NEXT_PUBLIC_COMFYUI_HOST=localhost
# Default ComfyUI port: 8188
# WSL2 + Windows ComfyUI: host.docker.internal
# Local Windows: localhost or 127.0.0.1
NEXT_PUBLIC_COMFYUI_PORT=8188
NEXT_PUBLIC_COMFYUI_PROTOCOL=http

# Gemini AI Provider Configuration (Optional)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-pro
